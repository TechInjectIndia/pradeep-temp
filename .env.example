# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://vsds:vsds@localhost:5432/vsds
DB_MAX_CONNECTIONS=20

# ── RabbitMQ ──────────────────────────────────────────────────────────────────
RABBITMQ_URL=amqp://vsds:vsds@localhost:5672
RABBITMQ_PREFETCH=5

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── WATI (WhatsApp API) ───────────────────────────────────────────────────────
WATI_BASE_URL=https://live-mt-server.wati.io/XXXXX
WATI_API_KEY=your_wati_api_key_here
WATI_TEMPLATE_NAME=specimen_dispatch

# ── Resend (Email API) ────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=VSDS Team

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# Copy to config.env and fill in values (config.env is gitignored)

# Firebase Admin SDK - for Firestore (teachers, logs). Use one of:
# 1. FIREBASE_CLIENT_EMAIL + FIREBASE_PRIVATE_KEY + FIREBASE_PROJECT_ID (preferred)
# 2. GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json
# 3. FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# FIREBASE_PRIVATE_KEY_ID=
# FIREBASE_CLIENT_ID=

WATI_API_URL=
WATI_API_KEY=
WATI_CHANNEL_NUMBER=
# Template name - must exist in WATI dashboard (Message Templates). Default: specimen_links
WATI_TEMPLATE_NAME=specimen_links
# Set to true for local dev to skip real WATI (messages are simulated)
USE_MOCK_WATI=false
# Website URL in messages (default: https://www.pradeeppublications.com)
APP_WEBSITE_URL=https://www.pradeeppublications.com
WATI_WEBHOOK_SECRET=
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_WEBHOOK_SECRET=
GCP_PROJECT=
GCP_LOCATION=us-central1
CLOUD_FUNCTIONS_URL=
ALGOLIA_APP_ID=
ALGOLIA_API_KEY=
ALGOLIA_TEACHER_INDEX=teachers
# Max messages per teacher per hour (0 = no limit). Used for frequency/rate limiting.
MAX_MESSAGES_PER_TEACHER_PER_HOUR=0
LOG_LEVEL=info

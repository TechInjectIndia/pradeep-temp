rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Admin-only access - all collections require Firebase Auth
    match /{document=**} {
      allow read, write: if request.auth != null && request.auth.token.admin == true;
    }

    // Phone/Email lookup collections - server-side only (Cloud Functions)
    match /phone_lookup/{phone} {
      allow read, write: if false; // Server-side only via Admin SDK
    }

    match /email_lookup/{email} {
      allow read, write: if false;
    }

    // Teachers master - server-side only
    match /teachers_master/{teacherId} {
      allow read, write: if false;
    }

    // Teachers raw - server-side only
    match /teachers_raw/{recordId} {
      allow read, write: if false;
    }

    // Specimen batches - server-side only
    match /specimen_batches/{batchId} {
      allow read, write: if false;
    }

    // Orders - server-side only
    match /orders/{orderId} {
      allow read, write: if false;
    }

    // Temp aggregation - server-side only
    match /temp_aggregation/{key} {
      allow read, write: if false;
    }

    // Comm log - server-side only
    match /comm_log/{messageId} {
      allow read, write: if false;
    }

    // Teacher communications - server-side only
    match /teacher_communications/{commId} {
      allow read, write: if false;
    }

    // Possible duplicates - server-side only
    match /possible_duplicates/{dupId} {
      allow read, write: if false;
    }

    // Batch errors - server-side only
    match /batch_errors/{errorId} {
      allow read, write: if false;
    }

    // Failed messages (DLQ) - server-side only
    match /failed_messages/{msgId} {
      allow read, write: if false;
    }
  }
}

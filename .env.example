# =============================================================================
# Copy to `.env.local` (Next.js) and/or `.env` (local tooling). Do not commit secrets.
#
# OCI / content scripts load `.env` then `.env.local` from the project root via dotenv:
#   npm run content:test-oci        — GetNamespace (+ HeadBucket if OCI_BUCKET is set)
#   npm run content:upload-oci      — upload chapter images (writes content-migration-upload.json; exits 1 on failure)
#   npm run content:verify-migration — HeadObject every manifest key + scan JSX for stray URLs; writes CONTENT_MIGRATION_REPORT.md
#   npm run content:migrate         — extract → upload → generate → apply-imports → verify (full pipeline)
# =============================================================================

# -----------------------------------------------------------------------------
# Next.js — public chapter image URLs (Object Storage)
# -----------------------------------------------------------------------------
# Prefix for every uploaded object (no trailing slash). App builds each image as:
#   ${NEXT_PUBLIC_OCI_IMAGE_BASE}/${encodeURIComponent(objectPath)}
#
# Example full object URL (one file in the bucket):
#   https://objectstorage.ap-hyderabad-1.oraclecloud.com/n/axp3fbwzpumh/b/uniformship/o/testimg_in_image_box_234_201_618_463.jpg
# → set the base to everything before the object name:
#   https://objectstorage.ap-hyderabad-1.oraclecloud.com/n/axp3fbwzpumh/b/uniformship/o
#
# If unset, chapter pages fall back to legacy remote URLs (see src/assets/content-images.ts).
# NEXT_PUBLIC_OCI_IMAGE_BASE=https://objectstorage.ap-hyderabad-1.oraclecloud.com/n/axp3fbwzpumh/b/uniformship/o
NEXT_PUBLIC_OCI_IMAGE_BASE=

# -----------------------------------------------------------------------------
# OCI — image upload script only (`npm run content:upload-oci`)
# -----------------------------------------------------------------------------
# API key auth is read from env only (no ~/.oci/config, no .oci profile file).
# You may use either OCI_* names below or ORACLE_* aliases (ORACLE_TENANCY_ID,
# ORACLE_USER_ID, ORACLE_FINGERPRINT, ORACLE_REGION, ORACLE_PRIVATE_KEY, ORACLE_BUCKET_NAME, ORACLE_NAMESPACE).
# See: https://docs.oracle.com/en-us/iaas/Content/API/Concepts/apisigningkey.htm
#
# Required: target bucket (must already exist).
# Example (matches URL above): uniformship
# OCI_BUCKET=uniformship
OCI_BUCKET=

# Optional: Object Storage namespace; if empty, the script calls GetNamespace.
# Example (matches URL above): axp3fbwzpumh
# OCI_NAMESPACE=axp3fbwzpumh
OCI_NAMESPACE=

# Required for upload: tenancy / user / fingerprint / region (same values you would put in a config file).
# OCI_TENANCY_OCID=ocid1.tenancy.oc1...
# OCI_USER_OCID=ocid1.user.oc1...
# OCI_FINGERPRINT=aa:bb:cc:...
# OCI_REGION=ap-hyderabad-1
OCI_TENANCY_OCID=
OCI_USER_OCID=
OCI_FINGERPRINT=
OCI_REGION=

# Private key — use ONE of the following (never commit the real key):
# 1) PEM in .env with escaped newlines, e.g. OCI_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----"
# 2) Base64 of the PEM file contents (good for CI secrets): OCI_PRIVATE_KEY_BASE64=...
# 3) Path to a .pem file outside the repo (local only): OCI_PRIVATE_KEY_PATH=/secure/path/api-key.pem
OCI_PRIVATE_KEY=
OCI_PRIVATE_KEY_BASE64=
OCI_PRIVATE_KEY_PATH=

# Optional: only if the private key is passphrase-protected
# OCI_PRIVATE_KEY_PASSPHRASE=
OCI_PRIVATE_KEY_PASSPHRASE=

# Optional: smoke test — upload only the first N manifest images (e.g. 1 while debugging).
# CONTENT_UPLOAD_LIMIT=1
# Or: npm run content:upload-oci:one
#
# Upload parallelism (default 20). Legacy URLs already in scripts/data/oci-uploaded-legacy-urls.json are skipped.
# CONTENT_UPLOAD_CONCURRENCY=20
# CONTENT_UPLOAD_RESET_CACHE=1   — delete URL cache and re-check bucket / re-upload as needed
# CONTENT_UPLOAD_NO_CACHE=1      — ignore cache file for this run only (no read/write)
#
# Upload script loads `.env` then `.env.local` automatically; then run:
#   npm run content:upload-oci
